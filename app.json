{
  "expo": {
    "name": "Anime1 Player",
    "slug": "rn-app",
    "owner": "eotw2054s-team",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.yiu.anime1player"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-video",
      "./plugins/withRemoteKeys.js"
    ],
    "extra": {
      "eas": {
        "projectId": "313eb4ec-182a-4cb3-82c2-97bf209ba6a6"
      },
      "releaseNotes": "• A1 設定面板而家可以捲動,遙控器/D-pad 落得到去「遙控」設定\n• 「允許遠端遙控」預設開;可改「自定義名稱」(例如 Projector)顯示喺遙控器播放器清單"
    },
    "updates": {
      "url": "https://anime1-ota.eotw2054.workers.dev",
      "requestHeaders": {
        "expo-channel-name": "production"
      }
    },
    "runtimeVersion": "1.0.1"
  }
}
