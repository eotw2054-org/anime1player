{
  "expo": {
    "name": "Anime1 Player",
    "slug": "rn-app",
    "owner": "eotw2054s-team",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.yiu.anime1player"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-video"
    ],
    "extra": {
      "eas": {
        "projectId": "313eb4ec-182a-4cb3-82c2-97bf209ba6a6"
      },
      "releaseNotes": "• 打直版:標題列加「收起/控制」掣,可手動收埋成個控制區\n• 移除「繼續觀看 xx:xx」顯示(續看功能照舊)"
    },
    "updates": {
      "url": "https://anime1-ota.eotw2054.workers.dev",
      "requestHeaders": {
        "expo-channel-name": "production"
      }
    },
    "runtimeVersion": "1.0.1"
  }
}
