{
  "expo": {
    "name": "Anime1 Player",
    "slug": "rn-app",
    "owner": "eotw2054s-team",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.yiu.anime1player"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-video",
      "./plugins/withRemoteKeys.js"
    ],
    "extra": {
      "eas": {
        "projectId": "313eb4ec-182a-4cb3-82c2-97bf209ba6a6"
      },
      "releaseNotes": "• 架構重整:螢幕方向鎖定 + 全螢幕防屏保 抽成 hooks,行為不變。\n• 麻煩喺手機試:入/出全螢幕會自動打橫/打直;全螢幕睇片唔好熄屏。"
    },
    "updates": {
      "url": "https://anime1-ota.eotw2054.workers.dev",
      "requestHeaders": {
        "expo-channel-name": "production"
      }
    },
    "runtimeVersion": "1.0.1"
  }
}
