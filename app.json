{
  "expo": {
    "name": "Anime1 Player",
    "slug": "rn-app",
    "owner": "eotw2054s-team",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.yiu.anime1player"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-video",
      "./plugins/withRemoteKeys.js"
    ],
    "extra": {
      "eas": {
        "projectId": "313eb4ec-182a-4cb3-82c2-97bf209ba6a6"
      },
      "releaseNotes": "• 同名分組嘅來源 chip 改成單行橫向拖動(唔再換行佔幾行),好似線路選擇咁。\n• 每個來源站只出一粒 chip;最愛一樣分組顯示多來源。"
    },
    "updates": {
      "url": "https://anime1-ota.eotw2054.workers.dev",
      "requestHeaders": {
        "expo-channel-name": "production"
      }
    },
    "runtimeVersion": "1.0.1"
  }
}
